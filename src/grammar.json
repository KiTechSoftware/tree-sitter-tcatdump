{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "tcatdump",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "file_block"
      }
    },
    "file_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "file_header"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "file_body"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "file_end"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "blank_lines"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "file_header": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "===== FILE:"
        },
        {
          "type": "FIELD",
          "name": "path",
          "content": {
            "type": "SYMBOL",
            "name": "file_path"
          }
        },
        {
          "type": "STRING",
          "value": "====="
        },
        {
          "type": "SYMBOL",
          "name": "newline"
        }
      ]
    },
    "file_end": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "===== END FILE:"
        },
        {
          "type": "FIELD",
          "name": "path",
          "content": {
            "type": "SYMBOL",
            "name": "file_path"
          }
        },
        {
          "type": "STRING",
          "value": "====="
        },
        {
          "type": "SYMBOL",
          "name": "newline"
        }
      ]
    },
    "file_path": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\\s=]+"
      }
    },
    "blank_lines": {
      "type": "PATTERN",
      "value": "\\r?\\n+"
    },
    "newline": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    },
    "file_body": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "body_line"
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "body_line"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}